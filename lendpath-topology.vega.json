{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "description": "LendPath Mortgage Platform \u2014 APM Service Network Topology (live traffic + errors)",
  "width": 1920,
  "height": 1280,
  "padding": 20,
  "autosize": "none",
  "signals": [
