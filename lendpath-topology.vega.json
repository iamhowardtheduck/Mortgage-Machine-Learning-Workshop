      "name": "nodeRadius",
      "value": 36
    },
    {
      "name": "selectedNode",
      "value": null,
      "on": [
        {
          "events": "symbol:click",
          "update": "datum.id"
        },
        {
          "events": "view:click[!event.item]",
          "update": "null"
        }
      ]
    }
  ],
