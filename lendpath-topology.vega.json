          "target": "redis:6379",
          "edgeKey": "lendpath-appraisal-service|redis:6379",
          "label": "Cache"
        }
      ]
    },
    {
      "name": "service-stats",
      "url": {
        "%context%": true,
        "%timefield%": "@timestamp",
        "index": "traces-apm-default",
        "body": {
          "size": 0,
          "query": {
            "bool": {
              "filter": [
                {
                  "term": {
                    "processor.event": "transaction"
                  }
                },
                {
                  "range": {
                    "@timestamp": {
                      "gte": "now-24h"
                    }
                  }
                }
              ]
            }
          },
          "aggs": {
            "by_service": {
              "terms": {
                "field": "service.name",
                "size": 20
              },
              "aggs": {
                "total": {
                  "value_count": {
                    "field": "transaction.id"
                  }
                },
                "errors": {
                  "filter": {
                    "term": {
                      "event.outcome": "failure"
                    }
                  },
                  "aggs": {
                    "count": {
                      "value_count": {
                        "field": "transaction.id"
                      }
                    }
                  }
                },
                "avg_duration": {
                  "avg": {
                    "field": "transaction.duration.us"
                  }
                }
              }
            }
          }
        }
      },
      "format": {
        "property": "aggregations.by_service.buckets"
      },
      "transform": [
        {
          "type": "formula",
          "as": "serviceId",
          "expr": "datum.key"
        },
        {
          "type": "formula",
          "as": "txnCount",
          "expr": "datum.doc_count"
        },
        {
          "type": "formula",
          "as": "errorCount",
          "expr": "datum.errors.count.value"
        },
        {
          "type": "formula",
          "as": "errorRate",
          "expr": "datum.doc_count > 0 ? datum.errors.count.value / datum.doc_count : 0"
        },
        {
          "type": "formula",
          "as": "avgDurationMs",
          "expr": "datum.avg_duration.value / 1000"
        }
      ]
    },
    {
      "name": "span-stats",
      "url": {
        "%context%": true,
        "%timefield%": "@timestamp",
        "index": "traces-apm-default",
        "body": {
          "size": 0,
          "query": {
            "bool": {
              "filter": [
                {
                  "term": {
                    "processor.event": "span"
                  }
                },
                {
                  "exists": {
                    "field": "destination.service.resource"
                  }
                },
                {
                  "range": {
                    "@timestamp": {
                      "gte": "now-24h"
                    }
                  }
                }
              ]
            }
          },
          "aggs": {
            "by_edge": {
              "terms": {
                "script": {
                  "source": "doc['service.name'].value + '|' + doc['destination.service.resource'].value",
                  "lang": "painless"
                },
                "size": 100
              },
              "aggs": {
                "span_errors": {
                  "filter": {
                    "term": {
                      "event.outcome": "failure"
                    }
                  },
                  "aggs": {
                    "count": {
                      "value_count": {
                        "field": "span.id"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "format": {
        "property": "aggregations.by_edge.buckets"
      },
      "transform": [
        {
          "type": "formula",
          "as": "edgeKey",
          "expr": "datum.key"
        },
        {
          "type": "formula",
          "as": "spanCount",
          "expr": "datum.doc_count"
        },
        {
          "type": "formula",
          "as": "spanErrors",
          "expr": "datum.span_errors.count.value"
        },
        {
          "type": "formula",
          "as": "spanErrorRate",
          "expr": "datum.doc_count > 0 ? datum.span_errors.count.value / datum.doc_count : 0"
        }
      ]
    },
    {
      "name": "nodes-display",
      "source": "node-defs",
      "transform": [
        {
          "type": "lookup",
          "from": "service-stats",
          "key": "serviceId",
          "fields": [
            "id"
          ],
          "as": [
            "stats"
          ],
          "default": {
            "txnCount": 0,
            "errorRate": 0,
            "avgDurationMs": 0
          }
        },
        {
          "type": "formula",
          "as": "txnCount",
          "expr": "datum.stats ? datum.stats.txnCount : 0"
        },
        {
          "type": "formula",
          "as": "errorRate",
          "expr": "datum.stats ? datum.stats.errorRate : 0"
        },
        {
          "type": "formula",
          "as": "avgDurationMs",
          "expr": "datum.stats ? datum.stats.avgDurationMs : 0"
        },
        {
          "type": "formula",
          "as": "hasLiveData",
          "expr": "datum.txnCount > 0"
        },
        {
          "type": "formula",
          "as": "nodeColor",
          "expr": "datum.group != 'app' ? datum.baseColor : (datum.errorRate > 0.15 ? '#C0392B' : datum.errorRate > 0.05 ? '#E67E22' : datum.hasLiveData ? '#1A9850' : datum.baseColor)"
        },
        {
          "type": "formula",
          "as": "nodeSize",
          "expr": "pow(nodeRadius * 2 + (datum.hasLiveData ? clamp(datum.txnCount / 20, 0, 16) : 0), 2)"
        },
        {
          "type": "formula",
          "as": "highlighted",
          "expr": "selectedNode != null && datum.id == selectedNode"
        },
        {
          "type": "formula",
          "as": "opacity",
          "expr": "selectedNode == null ? 1 : (datum.id == selectedNode ? 1 : 0.25)"
        },
        {
          "type": "formula",
          "as": "tooltip",
          "expr": "datum.hasLiveData ? (datum.id + ' | txn: ' + datum.txnCount + ' | errors: ' + format(datum.errorRate, '.0%') + ' | avg: ' + format(datum.avgDurationMs, '.0f') + 'ms') : datum.id"
        }
      ]
    },
    {
      "name": "edges-with-coords",
      "source": "edge-defs",
      "transform": [
        {
          "type": "lookup",
          "from": "node-defs",
          "key": "id",
          "fields": [
            "source"
          ],
          "as": [
            "src_node"
          ]
        },
        {
          "type": "lookup",
          "from": "node-defs",
          "key": "id",
          "fields": [
            "target"
          ],
          "as": [
            "tgt_node"
          ]
        },
        {
          "type": "lookup",
          "from": "span-stats",
          "key": "edgeKey",
          "fields": [
            "edgeKey"
          ],
          "as": [
            "edgeStats"
          ],
          "default": {
            "spanCount": 0,
            "spanErrorRate": 0
          }
        },
        {
          "type": "formula",
          "as": "x1",
          "expr": "datum.src_node.x"
        },
        {
          "type": "formula",
          "as": "y1",
          "expr": "datum.src_node.y"
        },
        {
          "type": "formula",
          "as": "x2",
          "expr": "datum.tgt_node.x"
        },
        {
          "type": "formula",
          "as": "y2",
          "expr": "datum.tgt_node.y"
        },
        {
          "type": "formula",
          "as": "mx",
          "expr": "(datum.x1 + datum.x2) / 2"
        },
        {
          "type": "formula",
          "as": "my",
          "expr": "(datum.y1 + datum.y2) / 2"
        },
        {
          "type": "formula",
          "as": "spanCount",
          "expr": "datum.edgeStats ? datum.edgeStats.spanCount : 0"
        },
        {
          "type": "formula",
          "as": "spanErrorRate",
          "expr": "datum.edgeStats ? datum.edgeStats.spanErrorRate : 0"
        },
        {
          "type": "formula",
          "as": "edgeWidth",
          "expr": "datum.spanCount > 0 ? clamp(1.5 + datum.spanCount / 40, 1.5, 8) : 1.5"
        },
        {
          "type": "formula",
          "as": "edgeColor",
          "expr": "datum.spanErrorRate > 0.15 ? '#C0392B' : datum.spanErrorRate > 0.05 ? '#E67E22' : datum.spanCount > 0 ? '#1A9850' : '#c8d4e3'"
        },
        {
          "type": "formula",
          "as": "highlighted",
          "expr": "selectedNode != null && (datum.source == selectedNode || datum.target == selectedNode)"
        }
      ]
    }
  ],
  "scales": [
    {
      "name": "errorColor",
      "type": "linear",
      "domain": [
        0,
        0.05,
        0.15,
        1
      ],
      "range": [
        "#1A9850",
        "#E67E22",
        "#C0392B",
        "#8B0000"
      ]
    }
  ],
  "marks": [
    {
      "name": "title-text",
      "type": "text",
      "encode": {
        "enter": {
          "x": {
            "value": 460
          },
          "y": {
            "value": 18
          },
          "align": {
            "value": "center"
          },
          "baseline": {
            "value": "middle"
          },
          "text": {
            "value": "LendPath \u2014 Service Network Topology"
          },
          "font": {
            "value": "Arial, sans-serif"
          },
          "fontSize": {
            "value": 15
          },
          "fontWeight": {
            "value": "bold"
          },
          "fill": {
            "value": "#1a2332"
          }
        }
      }
    },
    {
      "name": "edges",
      "type": "rule",
      "from": {
        "data": "edges-with-coords"
      },
      "encode": {
        "update": {
          "x": {
            "field": "x1"
          },
          "y": {
            "field": "y1"
          },
          "x2": {
            "field": "x2"
          },
          "y2": {
            "field": "y2"
          },
          "stroke": [
            {
              "test": "datum.highlighted",
              "field": "edgeColor"
            },
            {
              "test": "selectedNode == null",
              "field": "edgeColor"
            },
            {
              "value": "#e0e0e0"
            }
          ],
          "strokeWidth": [
            {
              "test": "datum.highlighted || selectedNode == null",
              "field": "edgeWidth"
            },
            {
              "value": 1
            }
          ],
          "strokeOpacity": [
            {
              "test": "selectedNode == null",
              "value": 0.7
            },
            {
              "test": "datum.highlighted",
              "value": 1
            },
            {
              "value": 0.1
            }
          ]
        }
      }
    },
    {
      "name": "arrowheads",
      "type": "symbol",
      "from": {
        "data": "edges-with-coords"
      },
      "encode": {
        "update": {
          "x": {
            "field": "x2"
          },
          "y": {
            "field": "y2"
          },
          "shape": {
            "value": "triangle"
          },
          "angle": {
            "signal": "atan2(datum.y2 - datum.y1, datum.x2 - datum.x1) * 180 / PI + 90"
          },
          "size": {
            "value": 80
          },
          "fill": [
            {
              "test": "datum.highlighted || selectedNode == null",
              "field": "edgeColor"
            },
            {
              "value": "#e0e0e0"
            }
          ],
          "fillOpacity": [
            {
              "test": "selectedNode == null",
              "value": 0.7
            },
            {
              "test": "datum.highlighted",
              "value": 1
            },
            {
              "value": 0.1
            }
          ]
        }
      }
    },
    {
      "name": "edge-span-count",
      "type": "text",
      "from": {
        "data": "edges-with-coords"
      },
      "encode": {
        "update": {
          "x": {
            "field": "mx"
          },
          "y": {
            "field": "my"
          },
          "text": {
            "signal": "datum.spanCount > 0 ? format(datum.spanCount, ',') : ''"
          },
          "align": {
            "value": "center"
          },
          "baseline": {
            "value": "middle"
          },
          "font": {
            "value": "Arial, sans-serif"
          },
          "fontSize": {
            "value": 8
          },
          "fontWeight": {
            "value": "bold"
          },
          "fill": {
            "field": "edgeColor"
          },
          "fillOpacity": [
            {
              "test": "selectedNode == null",
              "value": 0.85
            },
            {
              "test": "datum.highlighted",
              "value": 1
            },
            {
              "value": 0
            }
          ],
          "dx": {
            "value": 7
          }
        }
      }
    },
    {
      "name": "node-shadow",
      "type": "symbol",
      "from": {
        "data": "nodes-display"
      },
      "encode": {
        "update": {
          "x": {
            "field": "x"
          },
          "y": {
            "field": "y"
          },
          "shape": {
            "value": "circle"
          },
          "size": {
            "signal": "pow(nodeRadius * 2 + 8, 2)"
          },
          "fill": {
            "value": "#000"
          },
          "fillOpacity": {
            "value": 0.07
          },
          "dx": {
            "value": 3
          },
          "dy": {
            "value": 3
          }
        }
      }
    },
    {
      "name": "node-fill",
      "type": "symbol",
      "from": {
        "data": "nodes-display"
      },
      "encode": {
        "enter": {
          "cursor": {
            "value": "pointer"
          }
        },
        "update": {
          "x": {
            "field": "x"
          },
          "y": {
            "field": "y"
          },
          "shape": {
            "value": "circle"
          },
          "size": {
            "field": "nodeSize"
          },
          "fill": [
            {
              "test": "datum.highlighted",
              "value": "#fffbe6"
            },
            {
              "test": "datum.hasLiveData && datum.group == 'app'",
              "field": "nodeColor"
            },
            {
              "value": "#ffffff"
            }
          ],
          "fillOpacity": [
            {
              "test": "datum.highlighted || !datum.hasLiveData",
              "value": 1
            },
            {
              "value": 0.15
            }
          ],
          "stroke": {
            "field": "nodeColor"
          },
          "strokeWidth": [
            {
              "test": "datum.highlighted",
              "value": 3.5
            },
            {
              "test": "datum.hasLiveData",
              "value": 2.5
            },
            {
              "value": 1.5
            }
          ],
          "strokeOpacity": {
            "field": "opacity"
          },
          "tooltip": {
            "field": "tooltip"
          }
        }
      }
    },
    {
      "name": "node-dot",
      "type": "symbol",
      "from": {
        "data": "nodes-display"
      },
      "encode": {
        "update": {
          "x": {
            "field": "x"
          },
          "y": {
            "signal": "datum.y - nodeRadius + 10"
          },
          "shape": {
            "value": "circle"
          },
          "size": {
            "value": 200
          },
          "fill": {
            "field": "nodeColor"
          },
          "fillOpacity": {
            "field": "opacity"
          }
        }
      }
    },
    {
      "name": "node-txn-count",
      "type": "text",
      "from": {
        "data": "nodes-display"
      },
      "encode": {
        "update": {
          "x": {
            "field": "x"
          },
          "y": {
            "field": "y"
          },
          "text": {
            "signal": "datum.hasLiveData ? format(datum.txnCount, ',') : '\u2014'"
          },
          "align": {
            "value": "center"
          },
          "baseline": {
            "value": "middle"
          },
          "font": {
            "value": "Arial, sans-serif"
          },
          "fontSize": {
            "value": 11
          },
          "fontWeight": {
            "value": "bold"
          },
          "fill": [
            {
              "test": "datum.hasLiveData && datum.group == 'app'",
              "value": "#ffffff"
            },
            {
              "value": "#888888"
            }
          ],
